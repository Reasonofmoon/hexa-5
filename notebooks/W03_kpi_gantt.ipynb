   "source": [
    "## Step 5: 카테고리별 공정 현황 분석"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def analyze_by_category(df):\n",
    "    \"\"\"카테고리별 공정 현황 분석\"\"\"\n",
    "    \n",
    "    category_stats = df.groupby('category').agg({\n",
    "        'task_name': 'count',\n",
    "        'progress_rate': 'mean',\n",
    "        'quality_score': 'mean',\n",
    '        'safety_score': 'mean',\n',
    "        'is_delayed': 'sum',\n",
    "        'worker_count': 'sum'\n",
    "    }).rename(columns={\n",
    "        'task_name': 'task_count',\n",
    "        'is_delayed': 'delayed_count'\n",
    "    })\n",
    "    \n",
    "    category_stats['delay_rate'] = (category_stats['delayed_count'] / category_stats['task_count'] * 100)\n",
    "    category_stats['workers_per_task'] = category_stats['worker_count'] / category_stats['task_count']\n",
    "    \n",
    "    return category_stats\n",
    "\n",
    "# 카테고리별 분석\n",
    "category_stats = analyze_by_category(df_tasks)\n",
    "\n",
    "print('📂 카테고리별 공정 현황:')\n",
    "display(category_stats.round(1))\n",
    "\n",
    "# 시각화\n",
    "fig, axes = plt.subplots(2, 2, figsize=(15, 12))\n",
    "\n",
    "# 1. 평균 진행률\n",
    "category_stats['progress_rate'].plot(kind='bar', ax=axes[0,0], color='skyblue', alpha=0.8)\n",
    "axes[0,0].set_title('카테고리별 평균 진행률', fontsize=14, fontweight='bold')\n",
    "axes[0,0].set_ylabel('진행률 (%)')\n",
    "axes[0,0].tick_params(axis='x', rotation=45)\n",
    "\n",
    "# 2. 지연율\n",
    "category_stats['delay_rate'].plot(kind='bar', ax=axes[0,1], color='lightcoral', alpha=0.8)\n",
    "axes[0,1].set_title('카테고리별 지연율', fontsize=14, fontweight='bold')\n",
    "axes[0,1].set_ylabel('지연율 (%)')\n",
    "axes[0,1].tick_params(axis='x', rotation=45)\n",
    "\n",
    "# 3. 평균 품질 점수\n",
    "category_stats['quality_score'].plot(kind='bar', ax=axes[1,0], color='lightgreen', alpha=0.8)\n",
    "axes[1,0].set_title('카테고리별 평균 품질 점수', fontsize=14, fontweight='bold')\n",
    "axes[1,0].set_ylabel('품질 점수')\n",
    "axes[1,0].tick_params(axis='x', rotation=45)\n",
    "\n",
    "# 4. 작업자 수\n",
    "category_stats['worker_count'].plot(kind='bar', ax=axes[1,1], color='orange', alpha=0.8)\n",
    "axes[1,1].set_title('카테고리별 총 작업자 수', fontsize=14, fontweight='bold')\n",
    "axes[1,1].set_ylabel('작업자 수')\n",
    "axes[1,1].tick_params(axis='x', rotation=45)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
