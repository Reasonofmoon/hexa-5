  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 1: 건설 공정 샘플 데이터 생성"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 건설 공정 샘플 데이터 생성\n",
    "def generate_construction_data():\n",
    "    \"\"\"건설 공정 KPI 분석용 샘플 데이터 생성\"\"\"\n",
    "    \n",
    "    # 작업 공정 정의\n",
    "    tasks = [\n",
    "        {'task_name': '기계설치', 'category': '토목', 'planned_days': 15, 'priority': '상'},\n",
    "        {'task_name': '철근설치', 'category': '구조', 'planned_days': 20, 'priority': '상'},\n",
    "        {'task_name': '거푸집설치', 'category': '구조', 'planned_days': 18, 'priority': '상'},\n",
    "        {'task_name': '콘크리트타설', 'category': '구조', 'planned_days': 10, 'priority': '상'},\n",
    "        {'task_name': '내부마감', 'category': '마감', 'planned_days': 25, 'priority': '중'},\n",
    "        {'task_name': '외부마감', 'category': '마감', 'planned_days': 20, 'priority': '중'},\n",
    "        {'task_name': '기계설비', 'category': '설비', 'planned_days': 15, 'priority': '상'},\n",
    "        {'task_name': '전기설비', 'category': '설비', 'planned_days': 12, 'priority': '중'},\n",
    "        {'task_name': '조경공사', 'category': '외부', 'planned_days': 10, 'priority': '하'},\n",
    "        {'task_name': '최종점검', 'category': '마감', 'planned_days': 5, 'priority': '상'}\n",
    "    ]\n",
    "    \n",
    "    # 실제 공정 데이터 (일부 지연, 일부 조기완료)\n",
    "    base_date = datetime(2024, 6, 1)\n",
    "    \n",
    "    for i, task in enumerate(tasks):\n",
    "        # 시작일 (이전 작업 종료 후 1-3일 후)\n",
    "        if i == 0:\n",
    "            task['start_date'] = base_date\n",
    "        else:\n",
    "            prev_end = tasks[i-1]['end_date']\n",
    "            task['start_date'] = prev_end + timedelta(days=np.random.randint(1, 4))\n",
    "        \n",
    "        # 실제 소요일수 (계획보다 ±20% 범위에서 변동)\n",
    "        variance = np.random.uniform(-0.2, 0.3)\n",
    "        task['actual_days'] = max(1, int(task['planned_days'] * (1 + variance)))\n",
    "        task['end_date'] = task['start_date'] + timedelta(days=task['actual_days'])\n",
    "        \n",
    "        # 계획 종료일\n",
    "        task['planned_end_date'] = task['start_date'] + timedelta(days=task['planned_days'])\n",
    "        \n",
    "        # 공정율 및 품질 점수\n",
    "        task['progress_rate'] = min(100, max(30, np.random.normal(85, 10)))\n",
    "        task['quality_score'] = min(100, max(60, np.random.normal(85, 8)))\n",
    "        \n",
    "        # 안전 점수\n",
    "        task['safety_score'] = min(100, max(70, np.random.normal(90, 5)))\n",
    "        \n",
    "        # 작업자 수\n",
    "        task['worker_count'] = np.random.randint(8, 25)\n",
    "        \n",
    "        # 지연 여부\n",
    "        task['delay_days'] = max(0, (task['end_date'] - task['planned_end_date']).days)\n",
    "        task['is_delayed'] = task['delay_days'] > 0\n",
    "    \n",
    "    return pd.DataFrame(tasks)\n",
    "\n",
    "# 데이터 생성\n",
    "df_tasks = generate_construction_data()\n",
    "print('📋 건설 공정 데이터:')\n",
    "display(df_tasks.head())\n",
    "\n",
    "print('\\n📊 데이터 기본 통계:')\n",
    "print(f'• 총 작업 공정: {len(df_tasks)}개')\n",
    "print(f'• 지연된 작업: {df_tasks[\"is_delayed\"].sum()}개')\n",
    "print(f'• 평균 공정율: {df_tasks[\"progress_rate\"].mean():.1f}%')\n",
    "print(f'• 평균 품질 점수: {df_tasks[\"quality_score\"].mean():.1f}점')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 2: 공정 KPI 분석 함수"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def analyze_kpis(df):\n",
    "    \"\"\"건설 공정 KPI 종합 분석\"\"\"\n",
    "    \n",
    "    kpis = {\n",
    "        'schedule_performance': {\n",
    "            'on_time_rate': 100 - (df['is_delayed'].sum() / len(df) * 100),\n",
    "            'average_delay': df[df['is_delayed']]['delay_days'].mean() if df['is_delayed'].any() else 0,\n",
    "            'total_delay_days': df['delay_days'].sum()\n",
    "        },\n",
    "        'quality_performance': {\n",
    "            'average_quality': df['quality_score'].mean(),\n",
    "            'quality_issues': len(df[df['quality_score'] < 80]),\n",
    "            'quality_rate': 100 - (len(df[df['quality_score'] < 80]) / len(df) * 100)\n",
    "        },\n",
    "        'safety_performance': {\n",
    "            'average_safety': df['safety_score'].mean(),\n",
    "            'safety_issues': len(df[df['safety_score'] < 85]),\n",
    "            'safety_rate': 100 - (len(df[df['safety_score'] < 85]) / len(df) * 100)\n",
    "        },\n",
    "        'productivity': {\n",
    "            'average_progress': df['progress_rate'].mean(),\n",
    "            'total_workers': df['worker_count'].sum(),\n",
    "            'workers_per_task': df['worker_count'].mean()\n",
    "        }\n",
    "    }\n",
    "    \n",
    "    # 전체 점수 계산\n",
    "    overall_score = (\n",
    "        kpis['schedule_performance']['on_time_rate'] * 0.3 +\n",
    "        kpis['quality_performance']['quality_rate'] * 0.3 +\n",
    "        kpis['safety_performance']['safety_rate'] * 0.2 +\n",
    "        kpis['productivity']['average_progress'] * 0.2\n",
    "    )\n",
    "    \n",
    "    return kpis, overall_score\n",
    "\n",
    "# KPI 분석 실행\n",
    "kpis, overall_score = analyze_kpis(df_tasks)\n",
    "\n",
    "print('🎯 공정 KPI 분석 결과:')\n",
    "print(f'• 전체 종합 점수: {overall_score:.1f}점')\n",
    "print(f'• 일정 준수율: {kpis[\"schedule_performance\"][\"on_time_rate\"]:.1f}%')\n",
    "print(f'• 품질 달성률: {kpis[\"quality_performance\"][\"quality_rate\"]:.1f}%')\n",
    "print(f'• 안전 달성률: {kpis[\"safety_performance\"][\"safety_rate\"]:.1f}%')\n",
    "print(f'• 평균 진행률: {kpis[\"productivity\"][\"average_progress\"]:.1f}%')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 3: 간트차트 생성"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def create_gantt_chart(df):\n",
    "    \"\"\"간트차트 생성 (Plotly 사용)\"\"\"\n",
    "    \n",
    "    # 간트차트 데이터 준비\n",
    "    gantt_data = []\n",
    "    \n",
    "    for _, task in df.iterrows():\n",
    "        # 계획 일정\n",
    "        gantt_data.append({\n",
    "            'Task': task['task_name'],\n",
    "            'Start': task['start_date'],\n",
    "            'Finish': task['planned_end_date'],\n",
    "            'Resource': '계획',\n",
    "            'Category': task['category']\n",
    "        })\n",
    "        \n",
    "        # 실제 일정\n",
    "        gantt_data.append({\n",
    "            'Task': task['task_name'],\n",
    "            'Start': task['start_date'],\n",
    "            'Finish': task['end_date'],\n",
    "            'Resource': '실적',\n",
    "            'Category': task['category']\n",
    "        })\n",
    "    \n",
    "    df_gantt = pd.DataFrame(gantt_data)\n",
    "    \n",
    "    # 색상 설정\n",
    "    colors = {\n",
    "        '계획': 'lightblue',\n",
    "        '실적': 'lightcoral'\n",
    "    }\n",
    "    \n",
    "    # 간트차트 생성\n",
    "    fig = ff.create_gantt(\n",
    "        df_gantt,\n",
    "        colors=colors,\n",
    "        index_col='Resource',\n",
    "        show_colorbar=True,\n",
    "        group_tasks=True,\n",
    "        title='건설 공정 간트차트 (계획 vs 실적)'\n",
    "    )\n",
    "    \n",
    "    fig.update_layout(\n",
    "        xaxis_title='날짜',\n",
    "        yaxis_title='작업 공정',\n",
    "        height=600,\n",
    "        font=dict(size=12)\n",
    "    )\n",
    "    \n",
    "    return fig\n",
    "\n",
    "# 간트차트 생성\n",
    "gantt_fig = create_gantt_chart(df_tasks)\n",
    "gantt_fig.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 4: KPI 대시보드 시각화"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def create_kpi_dashboard(kpis, overall_score):\n",
    "    \"\"\"KPI 대시보드 생성\"\"\"\n",
    "    \n",
    "    # 서브플롯 생성\n",
    "    fig = make_subplots(\n",
    "        rows=2, cols=2,\n",
    "        subplot_titles=('일정 성과', '품질 성과', '안전 성과', '생산성'),\n",
    "        specs=[[{\"type\": \"indicator\"}, {\"type\": \"indicator\"}],\n",
    "               [{\"type\": \"indicator\"}, {\"type\": \"indicator\"}]]\n",
    "    )\n",
    "    \n",
    "    # 일정 성과\n",
    "    fig.add_trace(\n",
    "        go.Indicator(\n",
    "            mode=\"gauge+number+delta\",\n",
    "            value=kpis['schedule_performance']['on_time_rate'],\n",
    "            domain={'x': [0, 1], 'y': [0, 1]},\n",
    "            title={'text': \"일정 준수율 (%)\"},\n",
    "            gauge={\n",
    "                'axis': {'range': [None, 100]},\n",
    "                'bar': {'color': \"darkblue\"},\n",
    "                'steps': [\n",
    "                    {'range': [0, 50], 'color': \"lightgray\"},\n",
    "                    {'range': [50, 80], 'color': \"gray\"}\n",
    "                ],\n",
    "                'threshold': {\n",
    "                    'line': {'color': \"red\", 'width': 4},\n",
    "                    'thickness': 0.75,\n",
    "                    'value': 90\n",
    "                }\n",
    "            }\n",
    "        ),\n",
    "        row=1, col=1\n",
    "    )\n",
    "    \n",
    "    # 품질 성과\n",
    "    fig.add_trace(\n",
    "        go.Indicator(\n",
    "            mode=\"gauge+number\",\n",
    "            value=kpis['quality_performance']['quality_rate'],\n",
    "            domain={'x': [0, 1], 'y': [0, 1]},\n",
    "            title={'text': \"품질 달성률 (%)\"},\n",
    "            gauge={\n",
    "                'axis': {'range': [None, 100]},\n",
    "                'bar': {'color': \"green\"},\n",
    "                'steps': [\n",
    "                    {'range': [0, 60], 'color': \"lightgray\"},\n",
    "                    {'range': [60, 85], 'color': \"lightgreen\"}\n",
    "                ],\n",
    "                'threshold': {\n",
    "                    'line': {'color': \"red\", 'width': 4},\n",
    "                    'thickness': 0.75,\n",
    "                    'value': 95\n",
    "                }\n",
    "            }\n",
    "        ),\n",
    "        row=1, col=2\n",
    "    )\n",
    "    \n",
    "    # 안전 성과\n",
    "    fig.add_trace(\n",
    "        go.Indicator(\n",
    "            mode=\"gauge+number\",\n",
    "            value=kpis['safety_performance']['safety_rate'],\n",
    "            domain={'x': [0, 1], 'y': [0, 1]},\n",
    "            title={'text': \"안전 달성률 (%)\"},\n",
    "            gauge={\n",
    "                'axis': {'range': [None, 100]},\n",
    "                'bar': {'color': \"orange\"},\n",
    "                'steps': [\n",
    "                    {'range': [0, 70], 'color': \"lightgray\"},\n",
    "                    {'range': [70, 90], 'color': \"lightyellow\"}\n",
    "                ],\n",
    "                'threshold': {\n",
    "                    'line': {'color': \"red\", 'width': 4},\n",
    "                    'thickness': 0.75,\n",
    "                    'value': 95\n",
    "                }\n",
    "            }\n",
    "        ),\n",
    "        row=2, col=1\n",
    "    )\n",
    "    \n",
    "    # 생산성\n",
    "    fig.add_trace(\n",
    "        go.Indicator(\n",
    "            mode=\"gauge+number\",\n",
    "            value=kpis['productivity']['average_progress'],\n",
    "            domain={'x': [0, 1], 'y': [0, 1]},\n",
    "            title={'text': \"평균 진행률 (%)\"},\n",
    "            gauge={\n",
    "                'axis': {'range': [None, 100]},\n",
    "                'bar': {'color': \"purple\"},\n",
    "                'steps': [\n",
    "                    {'range': [0, 60], 'color': \"lightgray\"},\n",
    "                    {'range': [60, 85], 'color': \"lightpink\"}\n",
    "                ],\n",
    "                'threshold': {\n",
    "                    'line': {'color': \"red\", 'width': 4},\n",
    "                    'thickness': 0.75,\n",
    "                    'value': 90\n",
    "                }\n",
    "            }\n",
    "        ),\n",
    "        row=2, col=2\n",
    "    )\n",
    "    \n",
    "    fig.update_layout(\n",
    "        title=f'건설 공정 KPI 대시보드 (종합 점수: {overall_score:.1f}점)',\n",
    "        height=800,\n",
    "        font=dict(size=14)\n",
    "    )\n",
    "    \n",
    "    return fig\n",
    "\n",
    "# KPI 대시보드 생성\n",
    "kpi_dashboard = create_kpi_dashboard(kpis, overall_score)\n",
    "kpi_dashboard.show()"
   ]
  },
